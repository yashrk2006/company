# ============================================================
# Zorvia Digital — Environment Variable Template
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit the real .env file to git.
# ============================================================

# Supabase (Public, safe for frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key
# ⚠️ CRITICAL SECURITY WARNING:
# This key bypasses ALL Row-Level Security (RLS) in Supabase.
# It should ONLY ever exist in a secure backend (Node.js/Edge Function).
# Using it in a Vite frontend exposes it in the browser JavaScript bundle.
# For production, migrate admin operations to a Supabase Edge Function.
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key

# Mistral AI Configuration
# ⚠️ This key will be exposed in the browser JS bundle in a Vite app.
# For production, proxy AI requests through a backend API route or Edge Function.
VITE_MISTRAL_API_KEY=your-mistral-api-key
